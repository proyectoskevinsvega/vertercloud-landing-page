# Dominio del sitio web
VITE_SITE_URL=https://bravexcolombia.com

# API pública (entra por Cloudflare → Nginx → Load Balancer → Gateway)
VITE_API_URL=https://api.bravexcolombia.com

# Base path de la API
VITE_API_BASE_PATH=/api/v1

# Rutas del Frontend (solo navegación interna del sitio)
VITE_VPN_PATH=/vpn
VITE_AUTH_PATH=/auth
VITE_VPS_PATH=/vps

# Tenant SaaS
VITE_TENANT_SLUG=google